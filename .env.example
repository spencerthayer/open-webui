# USER_PERMISSIONS_FEATURES_API_KEYS=False
# USER_PERMISSIONS_FEATURES_MEMORIES=True
# USER_PERMISSIONS_FEATURES_AUTOMATIONS=False
# USER_PERMISSIONS_FEATURES_CALENDAR=True
# USER_PERMISSIONS_SETTINGS_INTERFACE=True

# ─────────────────────────────────────────────────────────────────────────────
# ACCESS CONTROL
# ─────────────────────────────────────────────────────────────────────────────

# Bypass model access control
# BYPASS_MODEL_ACCESS_CONTROL=False

# Bypass retrieval access control
# BYPASS_RETRIEVAL_ACCESS_CONTROL=False

# Enable unscoped collection names for retrieval
# ENABLE_RETRIEVAL_UNSCOPED_COLLECTIONS=False

# Bypass pydub preprocessing
# BYPASS_PYDUB_PREPROCESSING=False

# Enable OpenAI API passthrough
# ENABLE_OPENAI_API_PASSTHROUGH=False

# ─────────────────────────────────────────────────────────────────────────────
# ADMIN
# ─────────────────────────────────────────────────────────────────────────────

# Show admin details in UI
# SHOW_ADMIN_DETAILS=True

# Admin email display
# ADMIN_EMAIL=

# Enable admin export
# ENABLE_ADMIN_EXPORT=True

# Enable admin workspace content access
# ENABLE_ADMIN_WORKSPACE_CONTENT_ACCESS=True

# Bypass admin access control
# BYPASS_ADMIN_ACCESS_CONTROL=False

# Enable admin chat access
# ENABLE_ADMIN_CHAT_ACCESS=True

# Enable admin analytics
# ENABLE_ADMIN_ANALYTICS=True

# Enable community sharing
# ENABLE_COMMUNITY_SHARING=True

# Enable message rating
# ENABLE_MESSAGE_RATING=True

# Enable user webhooks
# ENABLE_USER_WEBHOOKS=False

# ─────────────────────────────────────────────────────────────────────────────
# TASKS (Auto-generation)
# ─────────────────────────────────────────────────────────────────────────────

# Task model (empty = use default model)
# TASK_MODEL=

# External task model
# TASK_MODEL_EXTERNAL=

# Title generation
# ENABLE_TITLE_GENERATION=True
# TITLE_GENERATION_PROMPT_TEMPLATE=

# Tags generation
# ENABLE_TAGS_GENERATION=True
# TAGS_GENERATION_PROMPT_TEMPLATE=

# Image prompt generation
# ENABLE_IMAGE_PROMPT_GENERATION=True
# IMAGE_PROMPT_GENERATION_PROMPT_TEMPLATE=

# Follow-up generation
# ENABLE_FOLLOW_UP_GENERATION=False
# FOLLOW_UP_GENERATION_PROMPT_TEMPLATE=

# Search query generation
# ENABLE_SEARCH_QUERY_GENERATION=True

# Retrieval query generation
# ENABLE_RETRIEVAL_QUERY_GENERATION=True
# QUERY_GENERATION_PROMPT_TEMPLATE=

# Autocomplete generation
# ENABLE_AUTOCOMPLETE_GENERATION=True
# AUTOCOMPLETE_GENERATION_INPUT_MAX_LENGTH=256
# AUTOCOMPLETE_GENERATION_PROMPT_TEMPLATE=

# Voice mode prompt
# ENABLE_VOICE_MODE_PROMPT=True
# VOICE_MODE_PROMPT_TEMPLATE=

# Tools function calling prompt
# TOOLS_FUNCTION_CALLING_PROMPT_TEMPLATE=

# ─────────────────────────────────────────────────────────────────────────────
# EVALUATION ARENA
# ─────────────────────────────────────────────────────────────────────────────

# Enable evaluation arena models
# ENABLE_EVALUATION_ARENA_MODELS=False
# EVALUATION_ARENA_MODELS=

# ─────────────────────────────────────────────────────────────────────────────
# FOLDERS / CHANNELS / NOTES / CALENDAR / AUTOMATIONS
# ─────────────────────────────────────────────────────────────────────────────

# Enable folders
# ENABLE_FOLDERS=True
# FOLDER_MAX_FILE_COUNT=100

# Enable channels
# ENABLE_CHANNELS=True

# Enable calendar
# ENABLE_CALENDAR=True

# Enable automations
# ENABLE_AUTOMATIONS=False
# AUTOMATION_MAX_COUNT=5
# AUTOMATION_MIN_INTERVAL=5

# Enable notes
# ENABLE_NOTES=True

# Enable user status
# ENABLE_USER_STATUS=True

# ─────────────────────────────────────────────────────────────────────────────
# PERFORMANCE
# ─────────────────────────────────────────────────────────────────────────────

# Thread pool size for async operations
# THREAD_POOL_SIZE=

# ─────────────────────────────────────────────────────────────────────────────
# OFFLINE MODE
# ─────────────────────────────────────────────────────────────────────────────

# Disable all external network requests
# OFFLINE_MODE=false

# Enable version update checks
# ENABLE_VERSION_UPDATE_CHECK=true

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE MISC
# ─────────────────────────────────────────────────────────────────────────────

# Enable session sharing across devices
# DATABASE_ENABLE_SESSION_SHARING=False

# Show public active users count
# ENABLE_PUBLIC_ACTIVE_USERS_COUNT=True

# Enable realtime chat save
# ENABLE_REALTIME_CHAT_SAVE=False

# Enable queries cache
# ENABLE_QUERIES_CACHE=False

# RAG system context
# RAG_SYSTEM_CONTEXT=False

# User active status update interval (seconds)
# DATABASE_USER_ACTIVE_STATUS_UPDATE_INTERVAL=

# ─────────────────────────────────────────────────────────────────────────────
# AUDIT LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Enable audit logging to stdout
# ENABLE_AUDIT_STDOUT=False

# Enable audit logging to file
# ENABLE_AUDIT_LOGS_FILE=True

# Audit log file path
# AUDIT_LOGS_FILE_PATH=$DATA_DIR/audit.log

# Audit log file rotation size
# AUDIT_LOG_FILE_ROTATION_SIZE=10MB

# Audit logger names (comma-separated)
# AUDIT_UVICORN_LOGGER_NAMES=uvicorn.access

# Audit log level: NONE | METADATA | REQUEST | REQUEST_RESPONSE
# AUDIT_LOG_LEVEL=NONE

# Max body log size (bytes)
# MAX_BODY_LOG_SIZE=2048

# Audit excluded paths (comma-separated)
# AUDIT_EXCLUDED_PATHS=/chats,/chat,/folders

# Audit included paths (comma-separated, overrides excluded)
# AUDIT_INCLUDED_PATHS=

# Enable audit for GET requests
# ENABLE_AUDIT_GET_REQUESTS=False

# ─────────────────────────────────────────────────────────────────────────────
# OPENTELEMETRY
# ─────────────────────────────────────────────────────────────────────────────

# Enable OpenTelemetry
# ENABLE_OTEL=False
# ENABLE_OTEL_TRACES=False
# ENABLE_OTEL_METRICS=False
# ENABLE_OTEL_LOGS=False

# OTLP endpoints
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_METRICS_EXPORTER_OTLP_ENDPOINT=
# OTEL_LOGS_EXPORTER_OTLP_ENDPOINT=

# OTLP insecure mode
# OTEL_EXPORTER_OTLP_INSECURE=False
# OTEL_METRICS_EXPORTER_OTLP_INSECURE=False
# OTEL_LOGS_EXPORTER_OTLP_INSECURE=False

# OTEL service name
# OTEL_SERVICE_NAME=open-webui

# OTEL resource attributes (comma-separated key=value)
# OTEL_RESOURCE_ATTRIBUTES=

# Traces sampler
# OTEL_TRACES_SAMPLER=parentbased_always_on

# Basic auth
# OTEL_BASIC_AUTH_USERNAME=
# OTEL_BASIC_AUTH_PASSWORD=
# OTEL_METRICS_BASIC_AUTH_USERNAME=
# OTEL_METRICS_BASIC_AUTH_PASSWORD=
# OTEL_LOGS_BASIC_AUTH_USERNAME=
# OTEL_LOGS_BASIC_AUTH_PASSWORD=

# Metrics export interval (milliseconds)
# OTEL_METRICS_EXPORT_INTERVAL_MILLIS=10000

# OTLP span exporter: grpc | http
# OTEL_OTLP_SPAN_EXPORTER=grpc
# OTEL_METRICS_OTLP_SPAN_EXPORTER=
# OTEL_LOGS_OTLP_SPAN_EXPORTER=

# ─────────────────────────────────────────────────────────────────────────────
# LICENSE
# ─────────────────────────────────────────────────────────────────────────────

# License key
# LICENSE_KEY=

# License blob path
# LICENSE_BLOB_PATH=

# License public key (PEM)
# LICENSE_PUBLIC_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# COMPRESSION
# ─────────────────────────────────────────────────────────────────────────────

# Enable compression middleware
# ENABLE_COMPRESSION_MIDDLEWARE=True

# ─────────────────────────────────────────────────────────────────────────────
# TOOLS/FUNCTIONS PIP OPTIONS
# ─────────────────────────────────────────────────────────────────────────────

# Install frontmatter requirements from tool/function files
# ENABLE_PIP_INSTALL_FRONTMATTER_REQUIREMENTS=True

# Additional pip install options
# PIP_OPTIONS=

# Additional pip index options
# PIP_PACKAGE_INDEX_OPTIONS=

# ─────────────────────────────────────────────────────────────────────────────
# SCARF ANALYTICS (DO NOT TRACK)
# ─────────────────────────────────────────────────────────────────────────────

# Disable Scarf analytics
# SCARF_NO_ANALYTICS=true

# Do Not Track
# DO_NOT_TRACK=true

# Disable anonymized telemetry
# ANONYMIZED_TELEMETRY=false
