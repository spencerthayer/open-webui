# RAG top-K results
# RAG_TOP_K=3

# RAG top-K for reranker
# RAG_TOP_K_RERANKER=3

# RAG relevance threshold
# RAG_RELEVANCE_THRESHOLD=0.0

# RAG hybrid BM25 weight
# RAG_HYBRID_BM25_WEIGHT=0.5

# Enable RAG hybrid search (vector + BM25)
# ENABLE_RAG_HYBRID_SEARCH=False

# Enable enriched texts for hybrid search
# ENABLE_RAG_HYBRID_SEARCH_ENRICHED_TEXTS=False

# RAG full context mode
# RAG_FULL_CONTEXT=False

# Max files for RAG
# RAG_FILE_MAX_COUNT=5

# Max file size for RAG (bytes)
# RAG_FILE_MAX_SIZE=20971520

# Image compression dimensions for RAG
# FILE_IMAGE_COMPRESSION_WIDTH=1600
# FILE_IMAGE_COMPRESSION_HEIGHT=900

# Allowed file extensions for RAG (comma-separated, empty = all)
# RAG_ALLOWED_FILE_EXTENSIONS=

# RAG embedding engine
# RAG_EMBEDDING_ENGINE=

# PDF extract images
# PDF_EXTRACT_IMAGES=False

# PDF loader mode
# PDF_LOADER_MODE=

# RAG embedding model
# RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Auto-update embedding model
# RAG_EMBEDDING_MODEL_AUTO_UPDATE=True

# Trust remote code for embedding model
