###############################################################################
# Open WebUI — Complete Environment Variable Reference
###############################################################################
# Copy this file to `.env` and uncomment/adjust the values you need.
# All values shown here are the defaults (or empty). Optional variables are
# commented out; required variables for specific features are noted.
###############################################################################

# ─────────────────────────────────────────────────────────────────────────────
# CORE / DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────

# Deployment environment: dev | test | prod
# ENV=dev

# Unique identifier for this deployment (useful in multi-instance setups)
# DEPLOYMENT_ID=

# Unique instance ID (auto-generated if unset)
# INSTANCE_ID=

# Docker detection — set true when running inside a Docker container
# DOCKER=false

# CUDA mode — set to 'true' to enable GPU acceleration (requires NVIDIA runtime)
# USE_CUDA_DOCKER=false

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Log format: leave empty for default, or set to 'json' for structured logging
# LOG_FORMAT=

# Global log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# GLOBAL_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# DATA / PATHS
# ─────────────────────────────────────────────────────────────────────────────

# Directory for persistent data (chats, uploads, vector DB, etc.)
# DATA_DIR=./backend/data

# Static files directory
# STATIC_DIR=./backend/open_webui/static

# Fonts directory
# FONTS_DIR=./backend/open_webui/static/fonts

# Frontend build directory
# FRONTEND_BUILD_DIR=./build

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# Database URL. Defaults to SQLite at $DATA_DIR/webui.db
# For PostgreSQL: postgresql://user:pass@host:5432/dbname
# For MySQL: mysql://user:pass@host:3306/dbname
# DATABASE_URL=sqlite:///$DATA_DIR/webui.db

# Alternative: set individual components (used if DATABASE_URL is unset)
# DATABASE_TYPE=postgresql
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_NAME=

# Database schema (PostgreSQL only)
# DATABASE_SCHEMA=

# Connection pool settings
# DATABASE_POOL_SIZE=
# DATABASE_POOL_MAX_OVERFLOW=0
# DATABASE_POOL_TIMEOUT=30
# DATABASE_POOL_RECYCLE=3600

# Enable SQLite WAL mode (recommended for concurrent access)
# DATABASE_ENABLE_SQLITE_WAL=True

# SQLite PRAGMA tuning — set any value to empty string to skip that PRAGMA
# DATABASE_SQLITE_PRAGMA_SYNCHRONOUS=NORMAL
# DATABASE_SQLITE_PRAGMA_BUSY_TIMEOUT=5000
# DATABASE_SQLITE_PRAGMA_CACHE_SIZE=-65536
# DATABASE_SQLITE_PRAGMA_TEMP_STORE=MEMORY
# DATABASE_SQLITE_PRAGMA_MMAP_SIZE=268435456
# DATABASE_SQLITE_PRAGMA_JOURNAL_SIZE_LIMIT=67108864

# Run database migrations on startup
# ENABLE_DB_MIGRATIONS=True

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────

# Redis URL for caching and session storage (enables Redis if set)
# REDIS_URL=redis://localhost:6379

# Redis cluster mode
# REDIS_CLUSTER=False

# Redis key prefix
# REDIS_KEY_PREFIX=open-webui

# Redis Sentinel configuration
# REDIS_SENTINEL_HOSTS=
# REDIS_SENTINEL_PORT=26379
# REDIS_SENTINEL_MAX_RETRY_COUNT=2

# Redis connection timeouts
# REDIS_SOCKET_CONNECT_TIMEOUT=
# REDIS_SOCKET_KEEPALIVE=False
# REDIS_HEALTH_CHECK_INTERVAL=
# REDIS_RECONNECT_DELAY=

# ─────────────────────────────────────────────────────────────────────────────
# UVICORN (Web Server)
# ─────────────────────────────────────────────────────────────────────────────

# Number of Uvicorn worker processes
# UVICORN_WORKERS=1

# ─────────────────────────────────────────────────────────────────────────────
# WEBSOCKET SUPPORT
# ─────────────────────────────────────────────────────────────────────────────

# Enable WebSocket support for real-time chat
# ENABLE_WEBSOCKET_SUPPORT=True

# WebSocket manager backend (leave empty for in-memory)
# WEBSOCKET_MANAGER=

# WebSocket Redis URL (defaults to REDIS_URL)
# WEBSOCKET_REDIS_URL=

# WebSocket Redis cluster mode
# WEBSOCKET_REDIS_CLUSTER=False

# WebSocket Redis lock timeout (seconds)
# WEBSOCKET_REDIS_LOCK_TIMEOUT=60

# WebSocket Sentinel configuration
# WEBSOCKET_SENTINEL_HOSTS=
# WEBSOCKET_SENTINEL_PORT=26379

# WebSocket server logging
# WEBSOCKET_SERVER_LOGGING=False
# WEBSOCKET_SERVER_ENGINEIO_LOGGING=False

# WebSocket ping settings
# WEBSOCKET_SERVER_PING_TIMEOUT=20
# WEBSOCKET_SERVER_PING_INTERVAL=25

# WebSocket event caller timeout (seconds, empty to disable)
# WEBSOCKET_EVENT_CALLER_TIMEOUT=

# ─────────────────────────────────────────────────────────────────────────────
# HTTP CLIENT (AIOHTTP)
# ─────────────────────────────────────────────────────────────────────────────

# Verify SSL certificates for outbound requests
# REQUESTS_VERIFY=True

# Default HTTP client timeout (seconds)
# AIOHTTP_CLIENT_TIMEOUT=300

# SSL for outbound HTTP sessions
# AIOHTTP_CLIENT_SESSION_SSL=True

# Follow 3xx redirects for outbound requests
# AIOHTTP_CLIENT_ALLOW_REDIRECTS=False

# User-Agent override for outbound web fetches
# USER_AGENT=

# Model list timeout (seconds)
# AIOHTTP_CLIENT_TIMEOUT_MODEL_LIST=10

# Tool server data timeout (seconds)
# AIOHTTP_CLIENT_TIMEOUT_TOOL_SERVER_DATA=10

# Tool server SSL
# AIOHTTP_CLIENT_SESSION_TOOL_SERVER_SSL=True

# Tool server timeout (seconds, empty = use AIOHTTP_CLIENT_TIMEOUT)
# AIOHTTP_CLIENT_TIMEOUT_TOOL_SERVER=

# MCP session.initialize() handshake timeout (seconds)
# MCP_INITIALIZE_TIMEOUT=10

# Connection pool settings
# AIOHTTP_POOL_CONNECTIONS=
# AIOHTTP_POOL_CONNECTIONS_PER_HOST=
# AIOHTTP_POOL_DNS_TTL=300

# RAG embedding timeout (seconds, empty to disable)
# RAG_EMBEDDING_TIMEOUT=

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────

# Allowed CORS origins (semicolon-separated, or '*' for all)
CORS_ALLOW_ORIGIN='*'

# Custom URL schemes for CORS (semicolon-separated, e.g. 'app://;tauri://')
# CORS_ALLOW_CUSTOM_SCHEMES=
# Set to false to keep memory tools enabled without adding memory context to the system context.
ENABLE_MEMORY_SYSTEM_CONTEXT=true

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────

# Enable authentication (REQUIRED — set to False only for trusted local setups)
# WEBUI_AUTH=True

# Secret key for JWT signing (REQUIRED when WEBUI_AUTH=True)
# Generate with: openssl rand -base64 42
# WEBUI_SECRET_KEY=

# Session cookie settings
# WEBUI_SESSION_COOKIE_SAME_SITE=lax
# WEBUI_SESSION_COOKIE_SECURE=false
# WEBUI_AUTH_COOKIE_SAME_SITE=lax
# WEBUI_AUTH_COOKIE_SECURE=false

# JWT expiration (e.g. '4w' for 4 weeks, '-1' for never)
# JWT_EXPIRES_IN=4w

# Enable API keys
# ENABLE_API_KEYS=True

# API key endpoint restrictions
# ENABLE_API_KEYS_ENDPOINT_RESTRICTIONS=False
# API_KEYS_ALLOWED_ENDPOINTS=

# Custom header name for API key authentication
# CUSTOM_API_KEY_HEADER=x-api-key

# Enable password authentication
# ENABLE_PASSWORD_AUTH=True

# Enable signup
# ENABLE_SIGNUP=True

# Require password confirmation on signup
# ENABLE_SIGNUP_PASSWORD_CONFIRMATION=False

# Enable login form
# ENABLE_LOGIN_FORM=True

# Enable password change form
# ENABLE_PASSWORD_CHANGE_FORM=True

# Enable initial admin signup (first user becomes admin)
# ENABLE_INITIAL_ADMIN_SIGNUP=False

# Admin account creation on startup (headless deployments)
# WEBUI_ADMIN_EMAIL=
# WEBUI_ADMIN_PASSWORD=
# WEBUI_ADMIN_NAME=Admin

# Trusted headers for authentication (when behind a reverse proxy)
# WEBUI_AUTH_TRUSTED_EMAIL_HEADER=
# WEBUI_AUTH_TRUSTED_NAME_HEADER=
# WEBUI_AUTH_TRUSTED_GROUPS_HEADER=
# WEBUI_AUTH_TRUSTED_ROLE_HEADER=

# Password validation
# ENABLE_PASSWORD_VALIDATION=False
# PASSWORD_VALIDATION_REGEX_PATTERN=
# PASSWORD_VALIDATION_HINT=

# Signout redirect URL
# WEBUI_AUTH_SIGNOUT_REDIRECT_URL=

# ─────────────────────────────────────────────────────────────────────────────
# OAUTH PROVIDERS
# ─────────────────────────────────────────────────────────────────────────────

# Enable OAuth signup
# ENABLE_OAUTH_SIGNUP=True

# Auto-redirect to OAuth provider
# OAUTH_AUTO_REDIRECT=False

# Include scope in refresh token
# OAUTH_REFRESH_TOKEN_INCLUDE_SCOPE=True

# Merge accounts by email
# OAUTH_MERGE_ACCOUNTS_BY_EMAIL=True

# OAuth client timeout
# OAUTH_CLIENT_TIMEOUT=

# OAuth scopes
# OAUTH_SCOPES=openid email profile

# OAuth timeout (seconds)
# OAUTH_TIMEOUT=60

# Token endpoint authentication method
# OAUTH_TOKEN_ENDPOINT_AUTH_METHOD=

# Code challenge method (PKCE)
# OAUTH_CODE_CHALLENGE_METHOD=

# OAuth provider display name
# OAUTH_PROVIDER_NAME=

# OAuth claims mapping
# OAUTH_SUB_CLAIM=sub
# OAUTH_USERNAME_CLAIM=preferred_username
# OAUTH_EMAIL_CLAIM=email
# OAUTH_PICTURE_CLAIM=picture
# OAUTH_GROUPS_CLAIM=groups

# Update user info on login
# OAUTH_UPDATE_EMAIL_ON_LOGIN=True
# OAUTH_UPDATE_NAME_ON_LOGIN=True
# OAUTH_UPDATE_PICTURE_ON_LOGIN=True

# Role and group management via OAuth
# ENABLE_OAUTH_ROLE_MANAGEMENT=True
# ENABLE_OAUTH_GROUP_MANAGEMENT=True
# ENABLE_OAUTH_GROUP_CREATION=True

# OAuth role/group separators and claims
# OAUTH_ROLES_CLAIM=roles
# OAUTH_ROLES_SEPARATOR=,
# OAUTH_GROUPS_SEPARATOR=;
# OAUTH_GROUP_DEFAULT_SHARE=true

# Allowed and admin roles
# OAUTH_ALLOWED_ROLES=user,admin
# OAUTH_ADMIN_ROLES=admin

# Allowed email domains
# OAUTH_ALLOWED_DOMAINS=

# Blocked groups
# OAUTH_BLOCKED_GROUPS=

# OAuth audience
# OAUTH_AUDIENCE=

# OAuth authorize params (JSON)
# OAUTH_AUTHORIZE_PARAMS=

# Include client_id in access token request
# OAUTH_ACCESS_TOKEN_REQUEST_INCLUDE_CLIENT_ID=False

# OAuth email fallback
# ENABLE_OAUTH_EMAIL_FALLBACK=False

# OAuth ID token cookie
# ENABLE_OAUTH_ID_TOKEN_COOKIE=True

# OAuth encryption keys (defaults to WEBUI_SECRET_KEY)
# OAUTH_CLIENT_INFO_ENCRYPTION_KEY=
# OAUTH_SESSION_TOKEN_ENCRYPTION_KEY=

# Max concurrent OAuth sessions per user per provider
# OAUTH_MAX_SESSIONS_PER_USER=10

# OAuth token exchange
# ENABLE_OAUTH_TOKEN_EXCHANGE=False

# OAuth back-channel logout (requires Redis)
# ENABLE_OAUTH_BACKCHANNEL_LOGOUT=False

# ── Google OAuth ────────────────────────────────────────────────────────────

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_SCOPE=openid email profile
# GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/google/callback
# GOOGLE_OAUTH_AUTHORIZE_PARAMS=

# ── Microsoft OAuth ─────────────────────────────────────────────────────────

# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_CLIENT_TENANT_ID=
# MICROSOFT_CLIENT_LOGIN_BASE_URL=https://login.microsoftonline.com
# MICROSOFT_OAUTH_SCOPE=openid email profile
# MICROSOFT_REDIRECT_URI=http://localhost:8080/oauth/microsoft/callback
# MICROSOFT_CLIENT_PICTURE_URL=

# ── GitHub OAuth ────────────────────────────────────────────────────────────

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CLIENT_SCOPE=read:user user:email
# GITHUB_CLIENT_REDIRECT_URI=http://localhost:8080/oauth/github/callback

# ── Generic OpenID Connect OAuth ────────────────────────────────────────────

# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OPENID_PROVIDER_URL=
# OPENID_END_SESSION_ENDPOINT=
# OPENID_REDIRECT_URI=http://localhost:8080/oauth/oidc/callback

# ── Feishu OAuth ────────────────────────────────────────────────────────────

# FEISHU_CLIENT_ID=
# FEISHU_CLIENT_SECRET=
# FEISHU_OAUTH_SCOPE=
# FEISHU_REDIRECT_URI=http://localhost:8080/oauth/feishu/callback

# ─────────────────────────────────────────────────────────────────────────────
# LDAP
# ─────────────────────────────────────────────────────────────────────────────

# Enable LDAP authentication
# ENABLE_LDAP=False

# LDAP server settings
# LDAP_SERVER_LABEL=LDAP
# LDAP_SERVER_HOST=ldap.example.com
# LDAP_SERVER_PORT=389
# LDAP_USE_TLS=False
# LDAP_CA_CERT_FILE=
# LDAP_VALIDATE_CERT=True
# LDAP_CIPHERS=ALL

# LDAP application credentials
# LDAP_APP_DN=cn=admin,dc=example,dc=com
# LDAP_APP_PASSWORD=

# LDAP user search
# LDAP_SEARCH_BASE=ou=users,dc=example,dc=com
# LDAP_SEARCH_FILTERS=
# LDAP_ATTRIBUTE_FOR_MAIL=mail
# LDAP_ATTRIBUTE_FOR_USERNAME=uid
# LDAP_ATTRIBUTE_FOR_GROUPS=memberOf

# LDAP group management
# ENABLE_LDAP_GROUP_MANAGEMENT=False
# ENABLE_LDAP_GROUP_CREATION=False

# ─────────────────────────────────────────────────────────────────────────────
# SCIM (System for Cross-domain Identity Management)
# ─────────────────────────────────────────────────────────────────────────────

# Enable SCIM provisioning
# ENABLE_SCIM=False
# SCIM_TOKEN=
# SCIM_AUTH_PROVIDER=

# ─────────────────────────────────────────────────────────────────────────────
# PERSISTENT CONFIG
# ─────────────────────────────────────────────────────────────────────────────

# Enable persistent configuration (stored in database)
# ENABLE_PERSISTENT_CONFIG=True

# Enable OAuth persistent config
# ENABLE_OAUTH_PERSISTENT_CONFIG=False

# Reset configuration on startup
# RESET_CONFIG_ON_START=False

# ─────────────────────────────────────────────────────────────────────────────
# WEBUI IDENTITY
# ─────────────────────────────────────────────────────────────────────────────

# WebUI display name
# WEBUI_NAME=Open WebUI

# WebUI URL (the public-facing URL)
# WEBUI_URL=

# Build hash (displayed in UI)
# WEBUI_BUILD_HASH=dev-build

# Trusted signature key
# TRUSTED_SIGNATURE_KEY=

# Webhook URL for external integrations
# WEBHOOK_URL=

# Banners (JSON array of {id, message, timestamp})
# WEBUI_BANNERS=[]

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# Safe mode — disables potentially dangerous features
# SAFE_MODE=False

# Enable easter eggs
# ENABLE_EASTER_EGGS=True

# Enable star sessions middleware
# ENABLE_STAR_SESSIONS_MIDDLEWARE=False

# Enable knowledge base execution
# ENABLE_KB_EXEC=False

# Enable profile image URL forwarding
# ENABLE_PROFILE_IMAGE_URL_FORWARDING=True

# Max data:image URI size for profile images (bytes, empty to disable)
# PROFILE_IMAGE_MAX_DATA_URI_SIZE=

# ─────────────────────────────────────────────────────────────────────────────
# FORWARD HEADERS (for reverse proxy deployments)
# ─────────────────────────────────────────────────────────────────────────────

# Forward user info headers to upstream services
# ENABLE_FORWARD_USER_INFO_HEADERS=False

# Custom header names
# FORWARD_USER_INFO_HEADER_USER_NAME=X-OpenWebUI-User-Name
# FORWARD_USER_INFO_HEADER_USER_ID=X-OpenWebUI-User-Id
# FORWARD_USER_INFO_HEADER_USER_EMAIL=X-OpenWebUI-User-Email
# FORWARD_USER_INFO_HEADER_USER_ROLE=X-OpenWebUI-User-Role
# FORWARD_SESSION_INFO_HEADER_MESSAGE_ID=X-OpenWebUI-Message-Id
# FORWARD_SESSION_INFO_HEADER_CHAT_ID=X-OpenWebUI-Chat-Id

# JWT-based user info forwarding (alternative to individual headers)
# FORWARD_USER_INFO_HEADER_JWT_SECRET=
# FORWARD_USER_INFO_HEADER_JWT=X-OpenWebUI-User-Jwt
# FORWARD_USER_INFO_HEADER_JWT_EXPIRES_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# PROGRESSIVE WEB APP
# ─────────────────────────────────────────────────────────────────────────────

# External PWA manifest URL
# EXTERNAL_PWA_MANIFEST_URL=

# ─────────────────────────────────────────────────────────────────────────────
# STORAGE PROVIDER
# ─────────────────────────────────────────────────────────────────────────────

# Storage backend: local | s3 | gcs | azure
# STORAGE_PROVIDER=local

# Enable local cache for remote storage
# STORAGE_LOCAL_CACHE=true

# ── S3 Storage ──────────────────────────────────────────────────────────────

# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION_NAME=
# S3_BUCKET_NAME=
# S3_KEY_PREFIX=
# S3_ENDPOINT_URL=
# S3_USE_ACCELERATE_ENDPOINT=false
# S3_ADDRESSING_STYLE=
# S3_ENABLE_TAGGING=false

# ── Google Cloud Storage ────────────────────────────────────────────────────

# GCS_BUCKET_NAME=
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ── Azure Blob Storage ──────────────────────────────────────────────────────

# AZURE_STORAGE_ENDPOINT=
# AZURE_STORAGE_CONTAINER_NAME=
# AZURE_STORAGE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA
# ─────────────────────────────────────────────────────────────────────────────

# Enable Ollama API integration
# ENABLE_OLLAMA_API=True

# Ollama API base URL
# OLLAMA_API_BASE_URL=http://localhost:11434/api

# Ollama base URL (for WebUI display/redirect)
# OLLAMA_BASE_URL=http://localhost:11434

# Multiple Ollama base URLs (semicolon-separated)
# OLLAMA_BASE_URLS=

# Kubernetes flag (set when running in K8s)
# K8S_FLAG=

# Use Docker-internal Ollama
# USE_OLLAMA_DOCKER=false

# ─────────────────────────────────────────────────────────────────────────────
# OPENAI API
# ─────────────────────────────────────────────────────────────────────────────

# Enable OpenAI API integration
# ENABLE_OPENAI_API=True

# OpenAI API key
# OPENAI_API_KEY=

# OpenAI API base URL (defaults to https://api.openai.com/v1)
# OPENAI_API_BASE_URL=

# Multiple OpenAI API keys (semicolon-separated)
# OPENAI_API_KEYS=

# Multiple OpenAI API base URLs (semicolon-separated)
# OPENAI_API_BASE_URLS=

# Gemini API key
# GEMINI_API_KEY=

# Gemini API base URL
# GEMINI_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# DIRECT CONNECTIONS
# ─────────────────────────────────────────────────────────────────────────────

# Enable direct connections to external APIs
# ENABLE_DIRECT_CONNECTIONS=False

# ─────────────────────────────────────────────────────────────────────────────
# MODELS
# ─────────────────────────────────────────────────────────────────────────────

# Enable base models cache
# ENABLE_BASE_MODELS_CACHE=False

# Custom model fallback
# ENABLE_CUSTOM_MODEL_FALLBACK=False

# Models cache TTL (seconds)
# MODELS_CACHE_TTL=1

# Default models (comma-separated list)
# DEFAULT_MODELS=

# Default pinned models
# DEFAULT_PINNED_MODELS=

# Default prompt suggestions (JSON array)
# DEFAULT_PROMPT_SUGGESTIONS=[]

# Model order list
# MODEL_ORDER_LIST=

# Default model metadata (JSON object)
# DEFAULT_MODEL_METADATA={}

# Default model params (JSON object)
# DEFAULT_MODEL_PARAMS={}

# Default user role on signup: user | pending | admin
# DEFAULT_USER_ROLE=pending

# Default group ID for new users
# DEFAULT_GROUP_ID=

# ─────────────────────────────────────────────────────────────────────────────
# CHAT
# ─────────────────────────────────────────────────────────────────────────────

# Convert base64 image URLs in chat responses
# ENABLE_CHAT_RESPONSE_BASE64_IMAGE_URL_CONVERSION=False

# Enable extension-to-MIME fallback for content type detection
# ENABLE_IMAGE_CONTENT_TYPE_EXTENSION_FALLBACK=False

# Stream delta chunk size
# CHAT_RESPONSE_STREAM_DELTA_CHUNK_SIZE=1

# Max tool-call iterations per chat response (-1 for unlimited)
# CHAT_RESPONSE_MAX_TOOL_CALL_ITERATIONS=256

# Enable stateful Responses API sessions (experimental)
# ENABLE_RESPONSES_API_STATEFUL=False

# Stream response chunk max buffer size
# CHAT_STREAM_RESPONSE_CHUNK_MAX_BUFFER_SIZE=

# ─────────────────────────────────────────────────────────────────────────────
# SENTENCE TRANSFORMERS (RAG Embeddings)
# ─────────────────────────────────────────────────────────────────────────────

# Backend: torch | onnx | openvino
# SENTENCE_TRANSFORMERS_BACKEND=torch

# Model kwargs (JSON)
# SENTENCE_TRANSFORMERS_MODEL_KWARGS=

# Cross-encoder backend
# SENTENCE_TRANSFORMERS_CROSS_ENCODER_BACKEND=torch

# Cross-encoder model kwargs (JSON)
# SENTENCE_TRANSFORMERS_CROSS_ENCODER_MODEL_KWARGS=

# Apply sigmoid normalization to cross-encoder scores
# SENTENCE_TRANSFORMERS_CROSS_ENCODER_SIGMOID_ACTIVATION_FUNCTION=True

# ─────────────────────────────────────────────────────────────────────────────
# TOOL SERVERS
# ─────────────────────────────────────────────────────────────────────────────

# Tool server connections (JSON array)
# TOOL_SERVER_CONNECTIONS=[]

# Terminal server connections (JSON array)
# TERMINAL_SERVER_CONNECTIONS=[]

# Terminal proxy headers (JSON object)
# TERMINAL_PROXY_HEADERS={}

# ─────────────────────────────────────────────────────────────────────────────
# CODE INTERPRETER / EXECUTION
# ─────────────────────────────────────────────────────────────────────────────

# Enable code execution
# ENABLE_CODE_EXECUTION=True

# Code execution engine: pyodide | jupyter
# CODE_EXECUTION_ENGINE=pyodide

# Jupyter URL for code execution
# CODE_EXECUTION_JUPYTER_URL=

# Jupyter authentication
# CODE_EXECUTION_JUPYTER_AUTH=
# CODE_EXECUTION_JUPYTER_AUTH_TOKEN=
# CODE_EXECUTION_JUPYTER_AUTH_PASSWORD=

# Jupyter timeout (seconds)
# CODE_EXECUTION_JUPYTER_TIMEOUT=60

# Enable code interpreter
# ENABLE_CODE_INTERPRETER=True

# Code interpreter engine: pyodide | jupyter
# CODE_INTERPRETER_ENGINE=pyodide

# Code interpreter prompt template
# CODE_INTERPRETER_PROMPT_TEMPLATE=

# Code interpreter Jupyter settings (inherit from CODE_EXECUTION_*)
# CODE_INTERPRETER_JUPYTER_URL=
# CODE_INTERPRETER_JUPYTER_AUTH=
# CODE_INTERPRETER_JUPYTER_AUTH_TOKEN=
# CODE_INTERPRETER_JUPYTER_AUTH_PASSWORD=
# CODE_INTERPRETER_JUPYTER_TIMEOUT=

# Blocked Python modules for code interpreter (comma-separated)
# CODE_INTERPRETER_BLOCKED_MODULES=

# ─────────────────────────────────────────────────────────────────────────────
# VECTOR DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# Vector database backend: chroma | mariadb-vector | milvus | qdrant | weaviate |
#                         opensearch | elasticsearch | pgvector | opengauss |
#                         pinecone | oracle23ai | s3 | valkey
# VECTOR_DB=chroma

# ── Chroma ──────────────────────────────────────────────────────────────────

# CHROMA_TENANT=default_tenant
# CHROMA_DATABASE=default_database
# CHROMA_HTTP_HOST=
# CHROMA_HTTP_PORT=8000
# CHROMA_CLIENT_AUTH_PROVIDER=
# CHROMA_CLIENT_AUTH_CREDENTIALS=
# CHROMA_HTTP_HEADERS=
# CHROMA_HTTP_SSL=false

# ── MariaDB Vector ──────────────────────────────────────────────────────────

# MARIADB_VECTOR_DB_URL=
# MARIADB_VECTOR_INITIALIZE_MAX_VECTOR_LENGTH=1536
# MARIADB_VECTOR_DISTANCE_STRATEGY=cosine
# MARIADB_VECTOR_INDEX_M=8
# MARIADB_VECTOR_POOL_SIZE=
# MARIADB_VECTOR_POOL_MAX_OVERFLOW=0
# MARIADB_VECTOR_POOL_TIMEOUT=30
# MARIADB_VECTOR_POOL_RECYCLE=3600

# ── Milvus ──────────────────────────────────────────────────────────────────

# MILVUS_URI=$DATA_DIR/vector_db/milvus.db
# MILVUS_DB=default
# MILVUS_TOKEN=
# MILVUS_INDEX_TYPE=HNSW
# MILVUS_METRIC_TYPE=COSINE
# MILVUS_HNSW_M=16
# MILVUS_HNSW_EFCONSTRUCTION=100
# MILVUS_IVF_FLAT_NLIST=128
# MILVUS_DISKANN_MAX_DEGREE=56
